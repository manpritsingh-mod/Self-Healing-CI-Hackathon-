// Jenkinsfile — COMPILATION ERROR scenario
// Simulates: "cannot find symbol" (classic Java compilation failure)
pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
            }
        }

        stage('Build') {
            steps {
                echo 'Compiling Java sources...'
                echo '[ERROR] /src/main/java/com/app/UserService.java:[23,45] error: cannot find symbol'
                echo '[ERROR]   symbol:   method getFullName()'
                echo '[ERROR]   location: class com.app.model.User'
                echo '[ERROR] /src/main/java/com/app/UserService.java:[24,20] error: incompatible types: String cannot be converted to int'
                echo '[INFO] 2 errors'
                echo '[INFO] BUILD FAILURE'
                echo '[INFO] Total time: 3.456 s'
                error('Compilation failed with 2 errors')
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
            }
        }
    }

    post {
        failure {
            echo '❌ Build failed! Triggering self-healing...'
            // TODO: Day 4 — call selfHeal() step here
        }
    }
}
