// Jenkinsfile — DEPENDENCY ERROR scenario
// Simulates: Maven dependency resolution failure
pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
            }
        }

        stage('Install Dependencies') {
            steps {
                echo 'Resolving Maven dependencies...'
                echo '[INFO] Downloading from central: https://repo.maven.apache.org/maven2/com/internal/lib-auth/2.1.0/lib-auth-2.1.0.pom'
                echo '[WARNING] Could not transfer artifact com.internal:lib-auth:pom:2.1.0 from/to central'
                echo '[ERROR] Failed to execute goal on project app-service: Could not resolve dependencies for project com.app:app-service:jar:1.0.0:'
                echo '[ERROR] Could not find artifact com.internal:lib-auth:jar:2.1.0 in central (https://repo.maven.apache.org/maven2)'
                echo '[ERROR] -> [Help 1]'
                echo '[INFO] BUILD FAILURE'
                echo '[INFO] Total time: 12.345 s'
                error('Dependency resolution failed: com.internal:lib-auth:2.1.0 not found')
            }
        }

        stage('Build') {
            steps {
                echo 'Building...'
            }
        }
    }

    post {
        failure {
            echo '❌ Dependencies failed! Triggering self-healing...'
        }
    }
}
