# ═══════════════════════════════════════════════════════════
# Self-Healing CI/CD Engine — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── AI Provider ──
AI_PROVIDER=ollama                    # claude | ollama
CLAUDE_API_KEY=                       # Required if AI_PROVIDER=claude
CLAUDE_MODEL=claude-sonnet-4-20250514
OLLAMA_URL=http://ollama:11434        # Docker service name
OLLAMA_MODEL=llama3

# ── Jenkins ──
JENKINS_URL=http://jenkins:8080
JENKINS_USER=admin
JENKINS_TOKEN=                        # Generate from Jenkins → User → Configure → API Token

# ── Slack ──
SLACK_WEBHOOK_URL=                    # Incoming webhook from Slack app

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=                        # App password for Gmail
NOTIFICATION_EMAIL=

# ── Engine Config ──
APP_PORT=5000
CONFIDENCE_THRESHOLD=90
MAX_LOOPS=3
TOKEN_DAILY_LIMIT=50000
